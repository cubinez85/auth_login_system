{% extends 'admin/master.html' %}

{% block body %}
<div class="container-fluid">
    <h2>🔐 Тестирование аутентификации</h2>
    <p class="text-muted">Инструменты для отладки API аутентификации</p>
    
    {% with messages = get_flashed_messages(with_categories=true) %}
        {% if messages %}
            {% for category, message in messages %}
                <div class="alert alert-{{ category }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endif %}
    {% endwith %}
    
    <div class="row">
        <!-- Регистрация -->
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0">📝 Тест регистрации</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ url_for('auth_test.api_test_register') }}">
                        <div class="mb-2">
                            <label>Email *</label>
                            <input type="email" name="email" class="form-control" required 
                                   placeholder="test@example.com" value="test_{{ now }}@example.com">
                        </div>
                        <div class="mb-2">
                            <label>Пароль *</label>
                            <input type="password" name="password" class="form-control" required 
                                   placeholder="Min 8 chars, A-Z, a-z, 0-9" value="TestPass123!">
                        </div>
                        <div class="row">
                            <div class="col">
                                <label>Фамилия</label>
                                <input type="text" name="last_name" class="form-control" value="Test">
                            </div>
                            <div class="col">
                                <label>Имя</label>
                                <input type="text" name="first_name" class="form-control" value="User">
                            </div>
                        </div>
                        <div class="mb-2">
                            <label>Роль</label>
                            <select name="role_id" class="form-select">
                                <option value="">-- Без роли --</option>
                                {% for role in roles %}
                                    <option value="{{ role.id }}">{{ role.name }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <button type="submit" class="btn btn-success w-100">🚀 Создать пользователя</button>
                    </form>
                </div>
            </div>
        </div>
        
        <!-- Вход -->
        <div class="col-md-6">
            <div class="card mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">🔑 Тест входа</h5>
                </div>
                <div class="card-body">
                    <form method="POST" action="{{ url_for('auth_test.api_test_login') }}">
                        <div class="mb-2">
                            <label>Email</label>
                            <input type="email" name="email" class="form-control" required 
                                   list="users_list" placeholder="Выберите пользователя">
                            <datalist id="users_list">
                                {% for user in users %}
                                    <option value="{{ user.email }}">
                                {% endfor %}
                            </datalist>
                        </div>
                        <div class="mb-3">
                            <label>Пароль</label>
                            <input type="password" name="password" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">🔐 Войти</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Результат: токены -->
    {% if last_tokens %}
    <div class="card mb-4 border-info">
        <div class="card-header bg-info text-white">
            <h5 class="mb-0">🎫 Сгенерированные токены</h5>
        </div>
        <div class="card-body">
            <p><strong>Пользователь:</strong> {{ last_user.email }} (ID: {{ last_user.id }})</p>
            
            <div class="mb-3">
                <label class="form-label">Access Token:</label>
                <div class="input-group">
                    <input type="text" class="form-control font-monospace" value="{{ last_tokens.access_token }}" readonly>
                    <button class="btn btn-outline-secondary" type="button" 
                            onclick="navigator.clipboard.writeText(this.previousElementSibling.value)">📋 Copy</button>
                </div>
            </div>
            
            <div class="mb-3">
                <label class="form-label">Refresh Token:</label>
                <div class="input-group">
                    <input type="text" class="form-control font-monospace" value="{{ last_tokens.refresh_token }}" readonly>
                    <button class="btn btn-outline-secondary" type="button"
                            onclick="navigator.clipboard.writeText(this.previousElementSibling.value)">📋 Copy</button>
                </div>
            </div>
            
            <div class="alert alert-secondary">
                <small>
                    <strong>Использование в API:</strong><br>
                    <code>Authorization: Bearer {{ last_tokens.access_token[:50] }}...</code>
                </small>
            </div>
        </div>
    </div>
    {% endif %}
    
    <!-- Декодирование токена -->
    <div class="card mb-4">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0">🔍 Декодировать токен</h5>
        </div>
        <div class="card-body">
            <form method="POST" action="{{ url_for('auth_test.api_test_decode') }}" class="row g-2">
                <div class="col-md-10">
                    <input type="text" name="token" class="form-control font-monospace" 
                           placeholder="Вставьте JWT токен..." value="{{ decoded_payload.token if decoded_payload else '' }}">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-secondary w-100">🔎 Decode</button>
                </div>
            </form>
            
            {% if decoded_payload %}
            <div class="mt-3">
                <h6>📦 Payload:</h6>
                <pre class="bg-light p-2 rounded"><code>{{ decoded_payload | tojson(indent=2) }}</code></pre>
                
                {% if is_blacklisted %}
                <div class="alert alert-danger">🚫 Этот токен в blacklist!</div>
                {% else %}
                <div class="alert alert-success">✅ Токен активен</div>
                {% endif %}
            </div>
            {% endif %}
        </div>
    </div>
    
    <!-- Blacklist токена -->
    <div class="card mb-4">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">🚫 Добавить токен в blacklist</h5>
        </div>
        <div class="card-body">
            <form method="POST" action="{{ url_for('auth_test.api_test_blacklist') }}" class="row g-2">
                <div class="col-md-10">
                    <input type="text" name="token" class="form-control font-monospace" 
                           placeholder="Токен для инвалидации...">
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-danger w-100">🗑️ Blacklist</button>
                </div>
            </form>
            <small class="text-muted">Используйте для тестирования logout или принудительного выхода пользователя</small>
        </div>
    </div>
    
    <!-- Быстрые ссылки -->
    <div class="card">
        <div class="card-header">
            <h5 class="mb-0">🔗 Быстрые ссылки API</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <a href="/api/auth/register/" target="_blank" class="btn btn-outline-success w-100 mb-2">
                        📡 POST /api/auth/register/
                    </a>
                </div>
                <div class="col-md-3">
                    <a href="/api/auth/login/" target="_blank" class="btn btn-outline-primary w-100 mb-2">
                        📡 POST /api/auth/login/
                    </a>
                </div>
                <div class="col-md-3">
                    <a href="/api/auth/profile/" target="_blank" class="btn btn-outline-info w-100 mb-2">
                        📡 PUT /api/auth/profile/
                    </a>
                </div>
                <div class="col-md-3">
                    <a href="/api/health/" target="_blank" class="btn btn-outline-secondary w-100 mb-2">
                        🏥 GET /api/health/
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
.font-monospace { font-family: monospace; font-size: 0.85em; }
.card-header h5 { margin: 0; font-size: 1.1rem; }
</style>

<script>
// Автозаполнение email для теста
document.addEventListener('DOMContentLoaded', function() {
    const emailInput = document.querySelector('input[name="email"][type="email"]');
    if (emailInput && !emailInput.value.includes('test_')) {
        const now = Math.floor(Date.now() / 1000);
        emailInput.value = `test_${now}@example.com`;
    }
});
</script>
{% endblock %}
